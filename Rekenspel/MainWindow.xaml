            <TextBlock HorizontalAlignment="Center" Margin="0,20,0,0" TextWrapping="Wrap" Text="🤓Het Rekenspel🤓" VerticalAlignment="Top" Width="270" Height="30"/>
            <TextBlock HorizontalAlignment="Left" Margin="64,71,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" RenderTransformOrigin="0.049,0.028" Width="156" Height="36"/>
            <TextBox HorizontalAlignment="Center" Margin="0,125,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="246" RenderTransformOrigin="0.525,0.67" Height="30"/>
            <Button Content="✅Check antwoord" HorizontalAlignment="Center" Margin="0,172,0,0" VerticalAlignment="Top" Width="246" Height="25" Background="LightGreen"/>
            <Button Content="Nieuwe som" HorizontalAlignment="Center" Margin="0,212,0,0" VerticalAlignment="Top" Width="246" Height="25" Background="LightBlue"/>
